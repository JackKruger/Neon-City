{
  "name": "neon-bay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test:map": "node --test scripts/map/*.test.mjs",
    "map:build": "node scripts/build-map.mjs --open-data && node scripts/compile-map.mjs --scope=all",
    "map:compile": "node scripts/compile-map.mjs",
    "map:validate": "node scripts/validate-compiled-map.mjs",
    "map:validate-streets": "node scripts/diagnose-streets.mjs",
    "map:download": "node scripts/build-map.mjs --download-open-data",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/three": "^0.185.0",
    "csv-parse": "^7.0.1",
    "geotiff": "^3.0.5",
    "meshoptimizer": "^1.2.0",
    "proj4": "^2.20.9",
    "shapefile": "^0.6.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
